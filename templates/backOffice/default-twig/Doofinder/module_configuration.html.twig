{% set tab = app.request.query.get('tab')|default('engine') %}
{% set sync = app.request.query.get('sync')|default('') %}

<style>
    #doofinder-config input[type=number] { min-width: 100px; }
</style>

<div class="card" id="doofinder-config">
    <div class="card-header">
        <h3 class="card-title mb-0">Doofinder</h3>
    </div>
    <div class="card-body">
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item">
                <button class="nav-link {{ tab == 'config' ? 'active' }}" data-bs-toggle="tab" data-bs-target="#config" type="button">{{ 'Configuration'|trans({}, 'doofinder.bo.default') }}</button>
            </li>
            <li class="nav-item">
                <button class="nav-link {{ tab == 'engine' ? 'active' }}" data-bs-toggle="tab" data-bs-target="#engine" type="button">{{ 'Search Engine'|trans({}, 'doofinder.bo.default') }}</button>
            </li>
            <li class="nav-item">
                <button class="nav-link {{ tab == 'front_hooks' ? 'active' }}" data-bs-toggle="tab" data-bs-target="#front_hooks" type="button">{{ 'Front Hooks'|trans({}, 'doofinder.bo.default') }}</button>
            </li>
            <li class="nav-item">
                <button class="nav-link {{ tab == 'excluded' ? 'active' }}" data-bs-toggle="tab" data-bs-target="#excluded" type="button">{{ 'Excluded Product'|trans({}, 'doofinder.bo.default') }}</button>
            </li>
        </ul>

        <div class="tab-content pt-3">
            {# Configuration tab #}
            <div id="config" class="tab-pane {{ tab == 'config' ? 'active show' }}">
                <h4>{{ 'Doofinder configuration'|trans({}, 'doofinder.bo.default') }}</h4>
                <a href="https://admin.doofinder.com/admin" target="_blank" rel="noopener">{{ 'Doofinder admin interface'|trans({}, 'doofinder.bo.default') }}</a>

                {{ form_start(configuration_form, {'action': path('admin_doofinder_config_configuration'), 'method': 'POST', 'attr': {'class': 'mt-3'}}) }}
                    <input type="hidden" name="{{ configuration_form.vars.full_name }}[success_url]" value="{{ path('admin.module.configure', {'module_code': 'Doofinder'}) }}">
                    <input type="hidden" name="{{ configuration_form.vars.full_name }}[error_url]" value="{{ path('admin.module.configure', {'module_code': 'Doofinder'}) }}">

                    {{ form_errors(configuration_form) }}

                    <div class="row">
                        <div class="col-md-6">
                            <h5>{{ 'Doofinder Server configuration'|trans({}, 'doofinder.bo.default') }}</h5>
                            {{ form_row(configuration_form.search_zone) }}
                            {{ form_row(configuration_form.hash_id) }}
                            <button type="submit" class="btn btn-success">{{ 'Save Configuration'|trans({}, 'doofinder.bo.default') }}</button>
                        </div>
                        <div class="col-md-6">
                            <h5>{{ 'Doofinder User configuration'|trans({}, 'doofinder.bo.default') }}</h5>
                            {{ form_row(configuration_form.user_id) }}
                            {{ form_row(configuration_form.user_token) }}
                        </div>
                    </div>
                    {{ form_rest(configuration_form) }}
                {{ form_end(configuration_form, {'render_rest': false}) }}
            </div>

            {# Excluded products tab #}
            <div id="excluded" class="tab-pane {{ tab == 'excluded' ? 'active show' }}">
                <ul>
                    {% for product in excluded_products %}
                        <li>
                            {{ product.title }}
                            <a href="{{ path('admin.products.update', {'product_id': product.id}) }}" target="_blank" rel="noopener">({{ product.ref }})</a>
                        </li>
                    {% endfor %}
                </ul>
            </div>

            {# Front hooks tab #}
            <div id="front_hooks" class="tab-pane {{ tab == 'front_hooks' ? 'active show' }}">
                {{ form_start(front_hooks_form, {'action': path('admin_doofinder_config_front_hooks'), 'method': 'POST', 'attr': {'class': 'mt-3'}}) }}
                    <input type="hidden" name="{{ front_hooks_form.vars.full_name }}[success_url]" value="{{ path('admin.module.configure', {'module_code': 'Doofinder'}) }}">
                    <input type="hidden" name="{{ front_hooks_form.vars.full_name }}[error_url]" value="{{ path('admin.module.configure', {'module_code': 'Doofinder'}) }}">

                    {{ form_errors(front_hooks_form) }}

                    <div class="row">
                        <div class="col-md-6">
                            <h5>{{ 'Doofinder Server configuration'|trans({}, 'doofinder.bo.default') }}</h5>
                            {{ form_row(front_hooks_form.hook_search_script) }}
                            {{ form_row(front_hooks_form.query_input_id) }}
                            {{ form_row(front_hooks_form.basic_search_bar) }}
                            <button type="submit" class="btn btn-success">{{ 'Save Configuration'|trans({}, 'doofinder.bo.default') }}</button>
                        </div>
                    </div>
                    {{ form_rest(front_hooks_form) }}
                {{ form_end(front_hooks_form, {'render_rest': false}) }}
            </div>

            {# Search engine tab #}
            <div id="engine" class="tab-pane {{ tab == 'engine' ? 'active show' }}">
                <h4>{{ 'Doofinder Search Engine'|trans({}, 'doofinder.bo.default') }}</h4>
                <a href="https://admin.doofinder.com/admin" target="_blank" rel="noopener">{{ 'Doofinder admin interface'|trans({}, 'doofinder.bo.default') }}</a>

                {% if sync == 'success' %}
                    <div class="alert alert-success mt-2">{{ 'Syncronization success'|trans({}, 'doofinder.bo.default') }}</div>
                {% endif %}
                {% if sync == 'failed' %}
                    <div class="alert alert-danger mt-2">{{ 'Syncronization failed'|trans({}, 'doofinder.bo.default') }}</div>
                {% endif %}

                <div class="mt-3">
                    {{ 'URL product feeds'|trans({}, 'doofinder.bo.default') }} :
                    <ul>
                        {% for feed in feeds %}
                            {% for datasource in feed %}
                                <li><a href="{{ datasource }}">{{ datasource }}</a></li>
                            {% endfor %}
                        {% endfor %}
                    </ul>
                </div>
                <hr>
                <div>
                    <table class="table table-striped table-sm">
                        <thead>
                        <tr>
                            <th>{{ 'Name'|trans({}, 'doofinder.bo.default') }}</th>
                            <th>{{ 'Language'|trans({}, 'doofinder.bo.default') }}</th>
                            <th>{{ 'Server'|trans({}, 'doofinder.bo.default') }}</th>
                            <th>{{ 'Hash ID'|trans({}, 'doofinder.bo.default') }}</th>
                            <th>{{ 'Currency'|trans({}, 'doofinder.bo.default') }}</th>
                            <th>{{ 'Status'|trans({}, 'doofinder.bo.default') }}</th>
                        </tr>
                        </thead>
                        <tbody>
                        <tr>
                            <td>{{ search_engine }}</td>
                            <td>{{ search_engine_lang }}</td>
                            <td>{{ search_engine_server }}</td>
                            <td>{{ search_engine_hash_id }}</td>
                            <td>{{ search_engine_currency }}</td>
                            <td>
                                {% if search_engine_status %}
                                    {{ 'Activated'|trans({}, 'doofinder.bo.default') }}
                                {% else %}
                                    {{ 'Disabled'|trans({}, 'doofinder.bo.default') }}
                                {% endif %}
                            </td>
                        </tr>
                        </tbody>
                    </table>

                    <a href="{{ path('admin_doofinder_api_import_all') }}" class="btn btn-success {{ not search_engine_status ? 'disabled' }}">{{ 'Syncronize all products'|trans({}, 'doofinder.bo.default') }}</a>
                </div>
            </div>
        </div>
    </div>
</div>
